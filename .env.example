# ══════════════════════════════════════════════════════════════════════
# Tribunal IA Portugal V8 — Configuração .env.example
# ══════════════════════════════════════════════════════════════════════
# Copia este ficheiro para .env e preenche os valores antes de arrancar.
# NUNCA commites o .env com valores reais para o repositório.

# ── Modo de execução ──────────────────────────────────────────────────
# development | production
ENV=development

# Activar modo governamental (bloqueia OpenRouter, exige encriptação, mTLS)
# Definir true apenas em infra homologada
GOV_MODE=false

# ── Backend LLM ───────────────────────────────────────────────────────
# Em GOV_MODE=true apenas "ollama" é permitido (soberania de dados)
# Fora de GOV_MODE: "openrouter" ou "ollama"
BACKEND=ollama

# Ollama (recomendado para .gov)
OLLAMA_URL=http://localhost:11434
OLLAMA_MODELO=llama3.3:70b

# mTLS para Ollama em produção governamental (comunicação interna segura)
# Gera certificados com: openssl req -x509 -newkey rsa:4096 -keyout client.key -out client.crt -days 365
# OLLAMA_MTLS_CERT=/certs/client.crt
# OLLAMA_MTLS_KEY=/certs/client.key
# OLLAMA_MTLS_CA=/certs/ca.crt

# OpenRouter — apenas para desenvolvimento/investigação, nunca em .gov com dados reais
# OPENROUTER_API_KEY=sk-or-v1-COLA_AQUI_A_TUA_CHAVE  # https://openrouter.ai/keys
# MODELO=openrouter/free

# ── RAG ───────────────────────────────────────────────────────────────
RAG_MODO=hibrido
RAG_EMBEDDING_MODELO=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
# Modelos PT de alta qualidade (requerem mais RAM):
# RAG_EMBEDDING_MODELO=PORTULAN/serafim-pt-small-100m-lingua-pt
# RAG_EMBEDDING_MODELO=neuralmind/bert-base-portuguese-cased
# RAG_EMBEDDING_MODELO=intfloat/multilingual-e5-large-instruct
RAG_RERANKING=true
RAG_RERANKER_BACKEND=local
RAG_RERANKER_MODELO=cross-encoder/ms-marco-MiniLM-L-6-v2
# COHERE_API_KEY=          # opcional: Cohere Rerank API
RAG_TOP_K=15
RAG_TOP_N=6

# ── API REST ──────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000

# OBRIGATÓRIO alterar em produção/GOV_MODE
# Gera com: python -c "import secrets; print(secrets.token_hex(32))"
API_SECRET_KEY=muda_isto_para_chave_segura_em_producao_min32chars

# Duração do token JWT em minutos (máximo 30 em produção)
API_ACCESS_TOKEN_EXPIRE_MINUTES=60

# Rate limiting (pedidos por minuto por IP)
API_RATE_LIMIT=30
API_RATE_LIMIT_BURST=10

# Origens CORS permitidas — NUNCA usar * em produção
# Em desenvolvimento:
API_CORS_ORIGINS=http://localhost:8501,http://localhost:3000
# Em produção .gov:
# API_CORS_ORIGINS=https://tribunal-ia.dgaj.mj.pt,https://intranet.tribunais.mj.pt

# ── Encriptação em repouso ────────────────────────────────────────────
# OBRIGATÓRIO em GOV_MODE=true e ENV=production
# Gera com: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# AUDIT_ENCRYPTION_KEY=SUBSTITUI_PELA_CHAVE_FERNET_GERADA

# ── Funcionalidades ───────────────────────────────────────────────────
GUARDAR_ATAS=true
ANONIMIZAR_ENTIDADES=true
CACHE_ENABLED=true
PARALELISMO=false
MODO_ECONOMICO=true
HISTORICO_ENABLED=true
EXPORTAR_PDF=true
CONSISTENCIA_CHECK=true
CONTRADITORIO_ENABLED=true
MULTILINGUE_ENABLED=true

# ── Orquestração ──────────────────────────────────────────────────────
# langgraph (recomendado) | imperativo (fallback se langgraph não instalado)
ORQUESTRACAO=langgraph

# ── Observability ─────────────────────────────────────────────────────
OBSERVABILITY_ENABLED=true
METRICS_PORT=9090
OTEL_SERVICE_NAME=tribunal-ia-v7
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317

# ── Geral ─────────────────────────────────────────────────────────────
MAX_RETRIES=5
REQUEST_TIMEOUT=180
LOG_LEVEL=INFO

# ── NOVAS OPÇÕES V8 ────────────────────────────────────────────────────

# Multi-query RAG com qualificador jurídico (recomendado: true)
RAG_MULTI_QUERY=true
RAG_N_QUERIES=5

# Deliberação entre juízes (recomendado: true, rondas=1)
DELIBERACAO_ENABLED=true
DELIBERACAO_RONDAS=1

# Agentes adicionais
ASSISTENTE_ENABLED=true
SINTESE_JUDICIAL_ENABLED=true

# Temperaturas dos juízes (diversidade de perspectivas)
TEMP_JUIZ_RIGOROSO=0.10
TEMP_JUIZ_GARANTISTA=0.20
TEMP_JUIZ_EQUILIBRADO=0.15
